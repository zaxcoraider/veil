# ── Veil — environment variables ─────────────────────────────────────────────
# Copy to .env.local for local dev, or set as Vercel environment variables.
# Never commit the actual values — .env* is in .gitignore.

# ── Contract ──────────────────────────────────────────────────────────────────
# VeilExecutor address on Arbitrum Sepolia (deploy with: npx tsx scripts/deploy.ts)
NEXT_PUBLIC_VEIL_CONTRACT=0x0000000000000000000000000000000000000000

# ── ChainGPT ──────────────────────────────────────────────────────────────────
# Get from https://app.chaingpt.org/apidashboard
# Leave empty to fall back to the built-in mock parser
CHAINGPT_API_KEY=

# ── TEE keypair ───────────────────────────────────────────────────────────────
# Generate with: npx tsx scripts/generate-tee-keys.ts
# Then paste the printed values here.

# ECDH P-256 public key (hex, 65 bytes uncompressed)
# Used by the frontend (noxEncrypt.ts) to encrypt the threshold
NEXT_PUBLIC_TEE_ECDH_PUBLIC_KEY=

# ECDH P-256 private key (base64, pkcs8)
# Used by /api/tee-evaluate to decrypt the threshold  ← KEEP SECRET
TEE_ECDH_PRIVATE_KEY=

# secp256k1 private key (Ethereum-compatible)
# Used by /api/tee-evaluate to sign evaluation results  ← KEEP SECRET
TEE_SIGNING_KEY=

# Ethereum address derived from TEE_SIGNING_KEY
# Must match the address passed to VeilExecutor constructor at deploy time
NEXT_PUBLIC_TEE_ADDRESS=

# ── Deployment (local/scripts only — not needed on Vercel) ───────────────────
# Deployer wallet private key for running scripts/deploy.ts
DEPLOYER_PRIVATE_KEY=

# Arbitrum Sepolia RPC — defaults to public endpoint
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Arbiscan API key for contract verification
ARBISCAN_API_KEY=
